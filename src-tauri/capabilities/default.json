{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "file://**" }]
    },
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "$APPDATA/**" }]
    },
    "log:default"
  ]
}
